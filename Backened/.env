# Production environment variables for docker-compose.prod.yml
DEBUG=False
SECRET_KEY=change-me-to-a-long-random-secret
ALLOWED_HOSTS=mobile-mechanics.awaisamjad.engineer,www.mobile-mechanics.awaisamjad.engineer,127.0.0.1,localhost

DB_NAME=mobilemechanic
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@db:5432/mobilemechanic

REDIS_PASSWORD=redis-password
CACHE_URL=redis://:redis-password@redis:6379/0

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@mobilemechanic.com

SECURE_SSL_REDIRECT=True
FRONTEND_URL=https://mobile-mechanics.awaisamjad.engineer



