# Development Environment Variables
# Copy this file to .env and fill in the values

# Django Settings
DEBUG=True
SECRET_KEY=django-insecure-your-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database Configuration
DB_ENGINE=django.db.backends.postgresql
DB_NAME=mobilemechanic
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@db:5432/mobilemechanic

# Cache Configuration
CACHE_URL=redis://redis:6379/0
REDIS_PASSWORD=redis-password

# Email Configuration (Gmail)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@mobilemechanic.com

# OTP Configuration
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6
MAX_OTP_ATTEMPTS=3

# Rate Limiting
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_BLOCK_DURATION=900

# Security (keep False for development, True for production)
SECURE_SSL_REDIRECT=False
SECURE_BROWSER_XSS_FILTER=True
X_FRAME_OPTIONS=DENY

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# Frontend URL
FRONTEND_URL=http://localhost:3000

# AWS (if using AWS S3 for uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=

# Sentry Error Tracking (optional)
SENTRY_DSN=

# Logging
LOG_LEVEL=DEBUG

# Django Admin
DJANGO_ADMIN_URL=admin/

# API Documentation
API_TITLE=MobileMechanic API
API_DESCRIPTION=API for Mobile Mechanic Service Platform
API_VERSION=1.0.0
